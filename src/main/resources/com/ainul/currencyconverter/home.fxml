<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<StackPane prefHeight="800.0" prefWidth="1000.0"
    xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="com.ainul.currencyconverter.controllers.HomeController">
    <children>
        <!-- Background image -->
        <ImageView fitWidth="1000.0" fitHeight="800.0" preserveRatio="false">
            <image>
                <Image url="@images/CCB.png" />
            </image>
        </ImageView>

        <!-- Dark overlay for readability -->
        <StackPane style="-fx-background-color: rgba(0,0,0,0.40);" />

        <BorderPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity"
            minWidth="-Infinity"
            prefHeight="800.0" prefWidth="1000.0" style="-fx-background-color: transparent;">

            <top>
                <VBox alignment="CENTER_LEFT" prefHeight="70.0"
                    style="-fx-background-color: rgba(20, 30, 48, 0.90); -fx-border-color: rgba(52,152,219,0.5); -fx-border-width: 0 0 2 0; -fx-padding: 12 20 12 20;"
                    BorderPane.alignment="CENTER">
                    <children>
                        <HBox alignment="CENTER_LEFT" spacing="12.0">
                            <children>
                                <Button mnemonicParsing="false" onAction="#handleBackToWelcome"
                                    prefHeight="34.0" prefWidth="90.0"
                                    style="-fx-font-size: 12; -fx-background-color: #34495e; -fx-text-fill: white; -fx-background-radius: 6; -fx-cursor: hand;"
                                    text="⬅ Back" />
                                <Button mnemonicParsing="false" onAction="#handleGoHome"
                                    prefHeight="34.0" prefWidth="90.0"
                                    style="-fx-font-size: 12; -fx-background-color: #2980b9; -fx-text-fill: white; -fx-background-radius: 6; -fx-cursor: hand;"
                                    text="🏠 Home" />
                                <Button mnemonicParsing="false" onAction="#handleOpenSettings"
                                    prefHeight="34.0" prefWidth="110.0"
                                    style="-fx-font-size: 12; -fx-background-color: #16a085; -fx-text-fill: white; -fx-background-radius: 6; -fx-cursor: hand;"
                                    text="⚙ Settings" />
                                <VBox spacing="2.0">
                                    <children>
                                        <Label text="💱 Currency Converter" textFill="WHITE">
                                            <font>
                                                <Font name="System Bold" size="22.0" />
                                            </font>
                                        </Label>
                                        <Label fx:id="welcomeLabel" textFill="#a0c4e0">
                                            <font>
                                                <Font size="12.0" />
                                            </font>
                                        </Label>
                                    </children>
                                </VBox>
                                <Region prefHeight="200.0" prefWidth="200.0" HBox.hgrow="ALWAYS" />
                                <Button mnemonicParsing="false" onAction="#handleLogout"
                                    prefHeight="34.0" prefWidth="100.0"
                                    style="-fx-font-size: 12; -fx-background-color: #c0392b; -fx-text-fill: white; -fx-background-radius: 6; -fx-cursor: hand;"
                                    text="🚪 Logout" />
                            </children>
                        </HBox>
                    </children>
                </VBox>
            </top>

            <center>
                <VBox spacing="18.0"
                    style="-fx-padding: 24;"
                    BorderPane.alignment="CENTER">
                    <children>
                        <!-- Conversion Card -->
                        <VBox spacing="16.0"
                            style="-fx-background-color: rgba(255,255,255,0.93); -fx-padding: 24; -fx-background-radius: 12; -fx-border-color: rgba(52,152,219,0.3); -fx-border-radius: 12; -fx-border-width: 1;">
                            <children>
                                <Label text="💰  Currency Conversion" textFill="#1a252f">
                                    <font>
                                        <Font name="System Bold" size="17.0" />
                                    </font>
                                </Label>

                                <!-- Amount -->
                                <HBox spacing="10.0" alignment="CENTER_LEFT">
                                    <children>
                                        <Label text="Amount:" prefWidth="80.0" textFill="#34495e">
                                            <font>
                                                <Font name="System Bold" size="13.0" />
                                            </font>
                                        </Label>
                                        <TextField fx:id="amountField" prefWidth="180.0"
                                            promptText="Enter amount"
                                            style="-fx-border-color: #bdc3c7; -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 8; -fx-font-size: 14;" />
                                        <Button mnemonicParsing="false"
                                            onAction="#handleClearAmount"
                                            prefHeight="32.0" prefWidth="80.0"
                                            style="-fx-font-size: 11; -fx-background-color: #95a5a6; -fx-text-fill: white; -fx-background-radius: 6; -fx-cursor: hand;"
                                            text="✖ Clear" />
                                    </children>
                                </HBox>

                                <!-- Currency Selectors -->
                                <HBox spacing="16.0" alignment="CENTER_LEFT">
                                    <children>
                                        <VBox spacing="5.0" prefWidth="320.0">
                                            <children>
                                                <Label text="From:" textFill="#34495e">
                                                    <font>
                                                        <Font name="System Bold" size="13.0" />
                                                    </font>
                                                </Label>
                                                <ComboBox fx:id="fromCurrencyCombo"
                                                    prefWidth="300.0"
                                                    style="-fx-border-radius: 6; -fx-background-radius: 6;" />
                                            </children>
                                        </VBox>
                                        <Button mnemonicParsing="false"
                                            onAction="#handleSwapCurrencies"
                                            prefHeight="42.0" prefWidth="52.0"
                                            style="-fx-font-size: 18; -fx-background-color: #3498db; -fx-text-fill: white; -fx-background-radius: 8; -fx-cursor: hand;"
                                            text="⇄" />
                                        <VBox spacing="5.0" prefWidth="320.0">
                                            <children>
                                                <Label text="To:" textFill="#34495e">
                                                    <font>
                                                        <Font name="System Bold" size="13.0" />
                                                    </font>
                                                </Label>
                                                <ComboBox fx:id="toCurrencyCombo" prefWidth="300.0"
                                                    style="-fx-border-radius: 6; -fx-background-radius: 6;" />
                                            </children>
                                        </VBox>
                                    </children>
                                </HBox>

                                <Separator />

                                <!-- Result -->
                                <VBox spacing="6.0"
                                    style="-fx-background-color: rgba(39,174,96,0.08); -fx-padding: 14; -fx-background-radius: 8; -fx-border-color: rgba(39,174,96,0.3); -fx-border-radius: 8; -fx-border-width: 1;">
                                    <children>
                                        <Label fx:id="resultLabel" text="Result: 0.00"
                                            textFill="#1e8449">
                                            <font>
                                                <Font name="System Bold" size="22.0" />
                                            </font>
                                        </Label>
                                        <Label fx:id="exchangeRateLabel" text="Exchange Rate: —"
                                            textFill="#5d6d7e">
                                            <font>
                                                <Font size="13.0" />
                                            </font>
                                        </Label>
                                    </children>
                                </VBox>

                                <!-- Action Buttons -->
                                <HBox spacing="10.0">
                                    <children>
                                        <Button mnemonicParsing="false"
                                            onAction="#handleAddToHistory"
                                            prefHeight="38.0" prefWidth="160.0"
                                            style="-fx-font-size: 12; -fx-font-weight: bold; -fx-background-color: #27ae60; -fx-text-fill: white; -fx-background-radius: 8; -fx-cursor: hand;"
                                            text="📋  Save to History" />
                                        <Region prefHeight="200.0" prefWidth="200.0"
                                            HBox.hgrow="ALWAYS" />
                                    </children>
                                </HBox>
                            </children>
                        </VBox>

                        <!-- History Card -->
                        <VBox spacing="10.0"
                            style="-fx-background-color: rgba(255,255,255,0.90); -fx-padding: 20; -fx-background-radius: 12; -fx-border-color: rgba(52,152,219,0.3); -fx-border-radius: 12; -fx-border-width: 1;"
                            prefHeight="230.0">
                            <children>
                                <HBox spacing="10.0" alignment="CENTER_LEFT">
                                    <children>
                                        <Label text="🕒  Recent Conversions" textFill="#1a252f">
                                            <font>
                                                <Font name="System Bold" size="16.0" />
                                            </font>
                                        </Label>
                                        <Region prefHeight="200.0" prefWidth="200.0"
                                            HBox.hgrow="ALWAYS" />
                                        <Button mnemonicParsing="false"
                                            onAction="#handleClearHistory"
                                            prefHeight="30.0" prefWidth="110.0"
                                            style="-fx-font-size: 11; -fx-background-color: #e74c3c; -fx-text-fill: white; -fx-background-radius: 6; -fx-cursor: hand;"
                                            text="🗑 Clear" />
                                    </children>
                                </HBox>
                                <TextArea fx:id="historyTextArea" prefHeight="160.0"
                                    prefWidth="200.0"
                                    wrapText="true" editable="false"
                                    style="-fx-font-size: 13; -fx-background-color: rgba(245,245,245,0.95); -fx-border-color: #dfe6e9; -fx-border-radius: 6;" />
                            </children>
                        </VBox>
                    </children>
                </VBox>
            </center>

            <bottom>
                <Label
                    text="© 2024 Currency Converter — Real-time accurate conversion at your fingertips."
                    textFill="#b0bec5"
                    style="-fx-padding: 10; -fx-background-color: rgba(20,30,48,0.7);"
                    BorderPane.alignment="CENTER">
                    <font>
                        <Font size="10.0" />
                    </font>
                </Label>
            </bottom>
        </BorderPane>
    </children>
</StackPane>