<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<StackPane prefHeight="800.0" prefWidth="1000.0"
    xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="com.ainul.currencyconverter.controllers.SettingsController">
    <children>
        <!-- Background image -->
        <ImageView fitWidth="1000.0" fitHeight="800.0" preserveRatio="false">
            <image>
                <Image url="@images/CCB.png" />
            </image>
        </ImageView>

        <!-- Dark overlay -->
        <StackPane style="-fx-background-color: rgba(0,0,0,0.42);" />

        <BorderPane prefHeight="800.0" prefWidth="1000.0" style="-fx-background-color: transparent;">
            <top>
                <VBox alignment="CENTER_LEFT" prefHeight="70.0"
                    style="-fx-background-color: rgba(20, 30, 48, 0.90); -fx-border-color: rgba(52,152,219,0.5); -fx-border-width: 0 0 2 0; -fx-padding: 12 20 12 20;"
                    BorderPane.alignment="CENTER">
                    <children>
                        <HBox alignment="CENTER_LEFT" spacing="12.0">
                            <children>
                                <Button mnemonicParsing="false" onAction="#handleBack"
                                    prefHeight="34.0" prefWidth="90.0"
                                    style="-fx-font-size: 12; -fx-background-color: #34495e; -fx-text-fill: white; -fx-background-radius: 6; -fx-cursor: hand;"
                                    text="⬅ Back" />
                                <Button mnemonicParsing="false" onAction="#handleHome"
                                    prefHeight="34.0" prefWidth="90.0"
                                    style="-fx-font-size: 12; -fx-background-color: #2980b9; -fx-text-fill: white; -fx-background-radius: 6; -fx-cursor: hand;"
                                    text="🏠 Home" />
                                <Label text="⚙  Settings" textFill="WHITE">
                                    <font>
                                        <Font name="System Bold" size="22.0" />
                                    </font>
                                </Label>
                                <Region prefHeight="20.0" prefWidth="20.0" HBox.hgrow="ALWAYS" />
                                <Button mnemonicParsing="false" onAction="#handleLogout"
                                    prefHeight="34.0" prefWidth="100.0"
                                    style="-fx-font-size: 12; -fx-background-color: #c0392b; -fx-text-fill: white; -fx-background-radius: 6; -fx-cursor: hand;"
                                    text="🚪 Logout" />
                            </children>
                        </HBox>
                    </children>
                </VBox>
            </top>

            <center>
                <VBox spacing="20.0" style="-fx-padding: 40 60 40 60;" BorderPane.alignment="CENTER">
                    <children>
                        <Label fx:id="settingsWelcomeLabel" text="Account Settings" textFill="WHITE">
                            <font>
                                <Font name="System Bold" size="28.0" />
                            </font>
                        </Label>

                        <Separator style="-fx-background-color: rgba(255,255,255,0.3);" />

                        <!-- Account Info Card -->
                        <VBox spacing="16.0"
                            style="-fx-background-color: rgba(255,255,255,0.93); -fx-padding: 28; -fx-background-radius: 12; -fx-border-color: rgba(52,152,219,0.3); -fx-border-radius: 12; -fx-border-width: 1;">
                            <children>
                                <Label text="👤  Account Information" textFill="#1a252f">
                                    <font>
                                        <Font name="System Bold" size="16.0" />
                                    </font>
                                </Label>
                                <Separator />
                                <HBox spacing="20.0" alignment="CENTER_LEFT">
                                    <children>
                                        <Label text="Username:" prefWidth="130.0" textFill="#5d6d7e">
                                            <font>
                                                <Font name="System Bold" size="13.0" />
                                            </font>
                                        </Label>
                                        <Label fx:id="usernameLabel" text="N/A" textFill="#1a252f">
                                            <font>
                                                <Font size="13.0" />
                                            </font>
                                        </Label>
                                    </children>
                                </HBox>
                                <HBox spacing="20.0" alignment="CENTER_LEFT">
                                    <children>
                                        <Label text="Email:" prefWidth="130.0" textFill="#5d6d7e">
                                            <font>
                                                <Font name="System Bold" size="13.0" />
                                            </font>
                                        </Label>
                                        <Label fx:id="emailLabel" text="N/A" textFill="#1a252f">
                                            <font>
                                                <Font size="13.0" />
                                            </font>
                                        </Label>
                                    </children>
                                </HBox>
                                <HBox spacing="20.0" alignment="CENTER_LEFT">
                                    <children>
                                        <Label text="Account Type:" prefWidth="130.0"
                                            textFill="#5d6d7e">
                                            <font>
                                                <Font name="System Bold" size="13.0" />
                                            </font>
                                        </Label>
                                        <Label fx:id="accountTypeLabel" text="N/A"
                                            textFill="#1a252f">
                                            <font>
                                                <Font size="13.0" />
                                            </font>
                                        </Label>
                                    </children>
                                </HBox>
                            </children>
                        </VBox>

                        <Label
                            text="View your active account details or jump to your saved conversion history below."
                            wrapText="true" textFill="#dce1e7">
                            <font>
                                <Font size="13.0" />
                            </font>
                        </Label>

                        <Button mnemonicParsing="false" onAction="#handleViewHistory"
                            prefHeight="44.0" prefWidth="260.0"
                            style="-fx-font-size: 14; -fx-font-weight: bold; -fx-background-color: #8e44ad; -fx-text-fill: white; -fx-background-radius: 10; -fx-cursor: hand;"
                            text="📜  View Conversion History" />
                    </children>
                </VBox>
            </center>
        </BorderPane>
    </children>
</StackPane>