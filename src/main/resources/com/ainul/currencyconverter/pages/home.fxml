<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<StackPane fx:id="rootStackPane"
    xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="com.ainul.currencyconverter.controllers.HomeController"
    stylesheets="@../styles/home.css"
    styleClass="root-stack-pane">
    <children>
        <!-- Background image -->
        <ImageView fx:id="backgroundImage" preserveRatio="true">
            <image>
                <Image url="@../images/background.png" />
            </image>
        </ImageView>

        <!-- Dark overlay for readability -->
        <StackPane styleClass="dark-overlay" />

        <BorderPane StackPane.alignment="TOP_CENTER"
            styleClass="root-border-pane">
            <top>
                <VBox alignment="CENTER_LEFT" prefHeight="70.0"
                    styleClass="top-nav"
                    BorderPane.alignment="CENTER">
                    <children>
                        <HBox alignment="CENTER_LEFT" spacing="12.0">
                            <children>
                                <Button mnemonicParsing="false" onAction="#handleBackToWelcome"
                                    prefHeight="34.0" prefWidth="90.0"
                                    styleClass="back-button"
                                    text="⬅ Back" />
                                <Button mnemonicParsing="false" onAction="#handleGoHome"
                                    prefHeight="34.0" prefWidth="90.0"
                                    styleClass="home-button"
                                    text="🏠 Home" />
                                <Button mnemonicParsing="false" onAction="#handleOpenSettings"
                                    prefHeight="34.0" prefWidth="110.0"
                                    styleClass="settings-button"
                                    text="⚙ Settings" />
                                <VBox spacing="2.0">
                                    <children>
                                        <Label text="💱 Currency Converter" textFill="WHITE">
                                            <font>
                                                <Font name="System Bold" size="22.0" />
                                            </font>
                                        </Label>
                                        <Label fx:id="welcomeLabel" textFill="#a0c4e0">
                                            <font>
                                                <Font size="12.0" />
                                            </font>
                                        </Label>
                                    </children>
                                </VBox>
                                <Region prefHeight="200.0" prefWidth="200.0" HBox.hgrow="ALWAYS" />
                                <Button mnemonicParsing="false" onAction="#handleLogout"
                                    prefHeight="34.0" prefWidth="100.0"
                                    styleClass="logout-button"
                                    text="🚪 Logout" />
                            </children>
                        </HBox>
                    </children>
                </VBox>
            </top>

            <center>
                <VBox spacing="18.0"
                    styleClass="content-wrapper"
                    BorderPane.alignment="CENTER"
                    VBox.vgrow="ALWAYS">
                    <children>
                        <!-- Conversion Card -->
                        <VBox spacing="16.0"
                            styleClass="conversion-card">
                            <children>
                                <Label text="💰  Currency Conversion" textFill="#1a252f">
                                    <font>
                                        <Font name="System Bold" size="17.0" />
                                    </font>
                                </Label>

                                <!-- Amount -->
                                <HBox spacing="10.0" alignment="CENTER_LEFT">
                                    <children>
                                        <Label text="Amount:" prefWidth="80.0" textFill="#34495e">
                                            <font>
                                                <Font name="System Bold" size="13.0" />
                                            </font>
                                        </Label>
                                        <TextField fx:id="amountField" prefWidth="180.0"
                                            promptText="Enter amount"
                                            styleClass="amount-input" />
                                        <Button mnemonicParsing="false"
                                            onAction="#handleClearAmount"
                                            prefHeight="32.0" prefWidth="80.0"
                                            styleClass="clear-amount-button"
                                            text="✖ Clear" />
                                    </children>
                                </HBox>

                                <!-- Currency Selectors -->
                                <HBox spacing="16.0" alignment="CENTER_LEFT">
                                    <children>
                                        <VBox spacing="5.0" prefWidth="320.0">
                                            <children>
                                                <Label text="From:" textFill="#34495e">
                                                    <font>
                                                        <Font name="System Bold" size="13.0" />
                                                    </font>
                                                </Label>
                                                <ComboBox fx:id="fromCurrencyCombo"
                                                    prefWidth="300.0"
                                                    styleClass="currency-combo" />
                                            </children>
                                        </VBox>
                                        <Button mnemonicParsing="false"
                                            onAction="#handleSwapCurrencies"
                                            prefHeight="42.0" prefWidth="52.0"
                                            styleClass="swap-button"
                                            text="⇄" />
                                        <VBox spacing="5.0" prefWidth="320.0">
                                            <children>
                                                <Label text="To:" textFill="#34495e">
                                                    <font>
                                                        <Font name="System Bold" size="13.0" />
                                                    </font>
                                                </Label>
                                                <ComboBox fx:id="toCurrencyCombo" prefWidth="300.0"
                                                    styleClass="currency-combo" />
                                            </children>
                                        </VBox>
                                    </children>
                                </HBox>

                                <Separator />

                                <!-- Result -->
                                <VBox spacing="6.0"
                                    styleClass="result-box">
                                    <children>
                                        <Label fx:id="resultLabel" text="Result: 0.00"
                                            textFill="#1e8449">
                                            <font>
                                                <Font name="System Bold" size="22.0" />
                                            </font>
                                        </Label>
                                        <Label fx:id="exchangeRateLabel" text="Exchange Rate: —"
                                            textFill="#5d6d7e">
                                            <font>
                                                <Font size="13.0" />
                                            </font>
                                        </Label>
                                    </children>
                                </VBox>

                                <!-- Action Buttons -->
                                <HBox spacing="10.0">
                                    <children>
                                        <Button mnemonicParsing="false"
                                            onAction="#handleAddToHistory"
                                            prefHeight="38.0" prefWidth="160.0"
                                            styleClass="save-history-button"
                                            text="📋  Save to History" />
                                        <Region prefHeight="200.0" prefWidth="200.0"
                                            HBox.hgrow="ALWAYS" />
                                    </children>
                                </HBox>
                            </children>
                        </VBox>

                        <!-- History Card -->
                        <VBox spacing="10.0"
                            styleClass="history-card"
                            VBox.vgrow="ALWAYS">
                            <children>
                                <HBox spacing="10.0" alignment="CENTER_LEFT">
                                    <children>
                                        <Label text="🕒  Recent Conversions" textFill="#1a252f">
                                            <font>
                                                <Font name="System Bold" size="16.0" />
                                            </font>
                                        </Label>
                                        <Region prefHeight="200.0" prefWidth="200.0"
                                            HBox.hgrow="ALWAYS" />
                                        <Button mnemonicParsing="false"
                                            onAction="#handleClearHistory"
                                            prefHeight="30.0" prefWidth="110.0"
                                            styleClass="clear-history-button"
                                            text="🗑 Clear" />
                                    </children>
                                </HBox>
                                <TextArea fx:id="historyTextArea" prefHeight="160.0" minHeight="50.0"
                                    prefWidth="100.0"
                                    wrapText="true" editable="false"
                                    styleClass="history-text-area"
                                    VBox.vgrow="ALWAYS" />
                            </children>
                        </VBox>
                    </children>
                </VBox>
            </center>

            <bottom>
                <Label
                    text="© 2024 Currency Converter — Real-time accurate conversion at your fingertips."
                    textFill="#b0bec5"
                    styleClass="footer-label"
                    BorderPane.alignment="CENTER">
                    <font>
                        <Font size="10.0" />
                    </font>
                </Label>
            </bottom>
        </BorderPane>
    </children>
</StackPane>