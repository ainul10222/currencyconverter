<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<StackPane fx:id="rootStackPane"
    xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="com.ainul.currencyconverter.controllers.HistoryController"
    stylesheets="@../styles/history.css"
    styleClass="root-stack-pane">
    <children>
        <!-- Background image -->
        <ImageView fx:id="backgroundImage" preserveRatio="true">
            <image>
                <Image url="@../images/background.png" />
            </image>
        </ImageView>

        <!-- Dark overlay -->
        <StackPane styleClass="dark-overlay" />

        <BorderPane StackPane.alignment="TOP_CENTER" prefHeight="800.0" prefWidth="1000.0" styleClass="root-border-pane">
            <top>
                <VBox alignment="CENTER_LEFT" prefHeight="70.0"
                    styleClass="top-nav"
                    BorderPane.alignment="CENTER">
                    <children>
                        <HBox alignment="CENTER_LEFT" spacing="12.0">
                            <children>
                                <Button mnemonicParsing="false" onAction="#handleBack"
                                    prefHeight="34.0" prefWidth="90.0"
                                    styleClass="back-button"
                                    text="⬅ Back" />
                                <Button mnemonicParsing="false" onAction="#handleHome"
                                    prefHeight="34.0" prefWidth="90.0"
                                    styleClass="home-button"
                                    text="🏠 Home" />
                                <Label fx:id="headerLabel" text="📜  Saved Conversion History"
                                    textFill="WHITE">
                                    <font>
                                        <Font name="System Bold" size="22.0" />
                                    </font>
                                </Label>
                                <Region prefHeight="20.0" prefWidth="20.0" HBox.hgrow="ALWAYS" />
                                <Button mnemonicParsing="false" onAction="#handleClearHistory"
                                    fx:id="clearHistoryButton"
                                    prefHeight="34.0" prefWidth="150.0"
                                    styleClass="clear-history-button"
                                    text="🗑 Clear History" />
                            </children>
                        </HBox>
                    </children>
                </VBox>
            </top>

            <center>
                <VBox spacing="16.0"
                    styleClass="content-wrapper"
                    BorderPane.alignment="CENTER">
                    <children>
                        <VBox spacing="12.0"
                            styleClass="history-card"
                            VBox.vgrow="ALWAYS">
                            <children>
                                <Label text="All your saved conversions appear below:"
                                    textFill="#5d6d7e">
                                    <font>
                                        <Font size="13.0" />
                                    </font>
                                </Label>
                                <TextArea fx:id="historyTextArea" prefHeight="580.0"
                                    prefWidth="900.0"
                                    wrapText="true" editable="false"
                                    styleClass="history-text-area" />
                            </children>
                        </VBox>
                    </children>
                </VBox>
            </center>
        </BorderPane>
    </children>
</StackPane>