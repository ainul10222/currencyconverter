<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<StackPane fx:id="rootStackPane"
    xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="com.ainul.currencyconverter.controllers.SettingsController"
    stylesheets="@../styles/settings.css"
    styleClass="root-stack-pane">
    <children>
        <!-- Background image -->
        <ImageView fx:id="backgroundImage" preserveRatio="true">
            <image>
                <Image url="@../images/background.png" />
            </image>
        </ImageView>

        <!-- Dark overlay -->
        <StackPane styleClass="dark-overlay" />

        <BorderPane StackPane.alignment="TOP_CENTER" styleClass="root-border-pane">
            <top>
                <VBox alignment="CENTER_LEFT" prefHeight="70.0"
                    styleClass="top-nav"
                    BorderPane.alignment="CENTER">
                    <children>
                        <HBox alignment="CENTER_LEFT" spacing="12.0">
                            <children>
                                <Button mnemonicParsing="false" onAction="#handleBack"
                                    prefHeight="34.0" prefWidth="90.0"
                                    styleClass="back-button"
                                    text="⬅ Back" />
                                <Button mnemonicParsing="false" onAction="#handleHome"
                                    prefHeight="34.0" prefWidth="90.0"
                                    styleClass="home-button"
                                    text="🏠 Home" />
                                <Label text="⚙  Settings" textFill="WHITE">
                                    <font>
                                        <Font name="System Bold" size="22.0" />
                                    </font>
                                </Label>
                                <Region prefHeight="20.0" prefWidth="20.0" HBox.hgrow="ALWAYS" />
                                <Button mnemonicParsing="false" onAction="#handleLogout"
                                    prefHeight="34.0" prefWidth="100.0"
                                    styleClass="logout-button"
                                    text="🚪 Logout" />
                            </children>
                        </HBox>
                    </children>
                </VBox>
            </top>

            <center>
                <VBox spacing="20.0" styleClass="content-wrapper" BorderPane.alignment="CENTER">
                    <children>
                        <Label fx:id="settingsWelcomeLabel" text="Account Settings" textFill="WHITE">
                            <font>
                                <Font name="System Bold" size="28.0" />
                            </font>
                        </Label>

                        <Separator styleClass="settings-separator" />

                        <!-- Account Info Card -->
                        <VBox spacing="16.0"
                            styleClass="account-card">
                            <children>
                                <Label text="👤  Account Information" textFill="#1a252f">
                                    <font>
                                        <Font name="System Bold" size="16.0" />
                                    </font>
                                </Label>
                                <Separator />
                                <HBox spacing="20.0" alignment="CENTER_LEFT">
                                    <children>
                                        <Label text="Username:" prefWidth="130.0" textFill="#5d6d7e">
                                            <font>
                                                <Font name="System Bold" size="13.0" />
                                            </font>
                                        </Label>
                                        <Label fx:id="usernameLabel" text="N/A" textFill="#1a252f">
                                            <font>
                                                <Font size="13.0" />
                                            </font>
                                        </Label>
                                    </children>
                                </HBox>
                                <HBox spacing="20.0" alignment="CENTER_LEFT">
                                    <children>
                                        <Label text="Email:" prefWidth="130.0" textFill="#5d6d7e">
                                            <font>
                                                <Font name="System Bold" size="13.0" />
                                            </font>
                                        </Label>
                                        <Label fx:id="emailLabel" text="N/A" textFill="#1a252f">
                                            <font>
                                                <Font size="13.0" />
                                            </font>
                                        </Label>
                                    </children>
                                </HBox>
                                <HBox spacing="20.0" alignment="CENTER_LEFT">
                                    <children>
                                        <Label text="Account Type:" prefWidth="130.0"
                                            textFill="#5d6d7e">
                                            <font>
                                                <Font name="System Bold" size="13.0" />
                                            </font>
                                        </Label>
                                        <Label fx:id="accountTypeLabel" text="N/A"
                                            textFill="#1a252f">
                                            <font>
                                                <Font size="13.0" />
                                            </font>
                                        </Label>
                                    </children>
                                </HBox>
                            </children>
                        </VBox>

                        <Label
                            text="View your active account details or jump to your saved conversion history below."
                            wrapText="true" textFill="#dce1e7">
                            <font>
                                <Font size="13.0" />
                            </font>
                        </Label>

                        <Button mnemonicParsing="false" onAction="#handleViewHistory"
                            prefHeight="44.0" prefWidth="260.0"
                            styleClass="view-history-button"
                            text="📜  View Conversion History" />
                    </children>
                </VBox>
            </center>
        </BorderPane>
    </children>
</StackPane>