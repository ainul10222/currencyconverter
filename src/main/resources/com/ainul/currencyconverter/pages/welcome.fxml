<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<StackPane
    xmlns="http://javafx.com/javafx/26"
    xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="com.ainul.currencyconverter.controllers.WelcomeController"
    fx:id="rootStackPane"
    stylesheets="@../styles/welcome.css"
    styleClass="root-stack-pane">
    <children>
        <!-- Background image - fills entire StackPane -->
        <ImageView fx:id="backgroundImage" StackPane.alignment="CENTER" preserveRatio="true">
            <image>
                <Image url="@../images/background.png" />
            </image>
        </ImageView>

        <!-- Subtle dark overlay -->
        <StackPane styleClass="overlay-stack-pane" />

        <BorderPane StackPane.alignment="TOP_CENTER" styleClass="border-pane">
            <top>
                <VBox alignment="CENTER" prefHeight="90.0" styleClass="welcome-header"
                    BorderPane.alignment="CENTER">
                    <children>
                        <Label text="💱 Currency Converter" styleClass="welcome-header-title">
                        </Label>
                        <Label text="Your trusted real-time currency conversion platform"
                            styleClass="welcome-header-subtitle">
                        </Label>
                    </children>
                </VBox>
            </top>

            <center>
                <VBox alignment="CENTER" BorderPane.alignment="CENTER" VBox.vgrow="ALWAYS">
                    <children>
                        <HBox alignment="CENTER" spacing="0" HBox.hgrow="ALWAYS">
                            <children>
                                <TabPane fx:id="tabPane" prefHeight="410.0"
                                    tabClosingPolicy="UNAVAILABLE"
                                    styleClass="auth-tab-pane">
                                    <tabs>
                                        <Tab text="🔑  Login">
                                            <VBox spacing="16.0"
                                                styleClass="login-tab-content"
                                                VBox.vgrow="ALWAYS">
                                                <children>
                                                    <Label text="Welcome Back" textFill="WHITE">
                                                        <font>
                                                            <Font name="System Bold" size="22.0" />
                                                        </font>
                                                    </Label>
                                                    <VBox spacing="6.0">
                                                        <children>
                                                            <Label text="Username"
                                                                textFill="#d0e8ff" />
                                                            <TextField fx:id="loginUsernameField"
                                                                promptText="Enter your username"
                                                                styleClass="auth-input" />
                                                        </children>
                                                    </VBox>
                                                    <VBox spacing="6.0">
                                                        <children>
                                                            <Label text="Password"
                                                                textFill="#d0e8ff" />
                                                            <PasswordField
                                                                fx:id="loginPasswordField"
                                                                promptText="Enter your password"
                                                                styleClass="auth-input" />
                                                        </children>
                                                    </VBox>
                                                    <Label fx:id="loginErrorLabel"
                                                        textFill="#ff6b6b"
                                                        wrapText="true" />
                                                    <Button mnemonicParsing="false"
                                                        onAction="#handleLogin"
                                                        prefHeight="42.0" prefWidth="220.0"
                                                        styleClass="login-button"
                                                        text="Login" />
                                                </children>
                                            </VBox>
                                        </Tab>
                                        <Tab text="📝  Sign Up">
                                            <VBox spacing="14.0"
                                                styleClass="signup-tab-content"
                                                VBox.vgrow="ALWAYS">
                                                <children>
                                                    <Label text="Create an Account" textFill="WHITE">
                                                        <font>
                                                            <Font name="System Bold" size="22.0" />
                                                        </font>
                                                    </Label>
                                                    <VBox spacing="5.0">
                                                        <children>
                                                            <Label text="Username"
                                                                textFill="#d0e8ff" />
                                                            <TextField fx:id="signupUsernameField"
                                                                promptText="Choose a username"
                                                                styleClass="auth-input" />
                                                        </children>
                                                    </VBox>
                                                    <VBox spacing="5.0">
                                                        <children>
                                                            <Label text="Email" textFill="#d0e8ff" />
                                                            <TextField fx:id="signupEmailField"
                                                                promptText="Enter your email"
                                                                styleClass="auth-input" />
                                                        </children>
                                                    </VBox>
                                                    <VBox spacing="5.0">
                                                        <children>
                                                            <Label text="Password"
                                                                textFill="#d0e8ff" />
                                                            <PasswordField
                                                                fx:id="signupPasswordField"
                                                                promptText="Min 6 characters"
                                                                styleClass="auth-input" />
                                                        </children>
                                                    </VBox>
                                                    <Label fx:id="signupErrorLabel"
                                                        textFill="#ff6b6b"
                                                        wrapText="true" />
                                                    <Label fx:id="signupSuccessLabel"
                                                        textFill="#2ecc71"
                                                        wrapText="true" />
                                                    <Button mnemonicParsing="false"
                                                        onAction="#handleSignup"
                                                        prefHeight="42.0" prefWidth="220.0"
                                                        styleClass="signup-button"
                                                        text="Create Account" />
                                                </children>
                                            </VBox>
                                        </Tab>
                                    </tabs>
                                </TabPane>
                            </children>
                        </HBox>
                        <HBox alignment="CENTER" spacing="14.0">
                            <padding>
                                <Insets top="14.0" />
                            </padding>
                            <children>
                                <Label text="Or continue without an account:" textFill="#e0e0e0" />
                                <Button mnemonicParsing="false" onAction="#handleGuestLogin"
                                    prefHeight="38.0" prefWidth="140.0"
                                    styleClass="guest-button"
                                    text="👤  Guest User" />
                            </children>
                        </HBox>
                    </children>
                    <padding>
                        <Insets bottom="10.0" left="20.0" right="20.0" top="10.0" />
                    </padding>
                </VBox>
            </center>

            <bottom>
                <Label text="© 2026 Currency Converter. All rights reserved." textFill="#aab7c4"
                    BorderPane.alignment="CENTER">
                    <font>
                        <Font size="11.0" />
                    </font>
                    <padding>
                        <Insets bottom="12.0" top="6.0" />
                    </padding>
                </Label>
            </bottom>
        </BorderPane>
    </children>
</StackPane>