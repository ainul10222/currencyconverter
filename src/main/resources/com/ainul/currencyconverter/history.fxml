<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<StackPane prefHeight="800.0" prefWidth="1000.0"
    xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="com.ainul.currencyconverter.controllers.HistoryController">
    <children>
        <!-- Background image -->
        <ImageView fitWidth="1000.0" fitHeight="800.0" preserveRatio="false">
            <image>
                <Image url="@images/CCB.png" />
            </image>
        </ImageView>

        <!-- Dark overlay -->
        <StackPane style="-fx-background-color: rgba(0,0,0,0.42);" />

        <BorderPane prefHeight="800.0" prefWidth="1000.0" style="-fx-background-color: transparent;">
            <top>
                <VBox alignment="CENTER_LEFT" prefHeight="70.0"
                    style="-fx-background-color: rgba(20, 30, 48, 0.90); -fx-border-color: rgba(52,152,219,0.5); -fx-border-width: 0 0 2 0; -fx-padding: 12 20 12 20;"
                    BorderPane.alignment="CENTER">
                    <children>
                        <HBox alignment="CENTER_LEFT" spacing="12.0">
                            <children>
                                <Button mnemonicParsing="false" onAction="#handleBack"
                                    prefHeight="34.0" prefWidth="90.0"
                                    style="-fx-font-size: 12; -fx-background-color: #34495e; -fx-text-fill: white; -fx-background-radius: 6; -fx-cursor: hand;"
                                    text="⬅ Back" />
                                <Button mnemonicParsing="false" onAction="#handleHome"
                                    prefHeight="34.0" prefWidth="90.0"
                                    style="-fx-font-size: 12; -fx-background-color: #2980b9; -fx-text-fill: white; -fx-background-radius: 6; -fx-cursor: hand;"
                                    text="🏠 Home" />
                                <Label fx:id="headerLabel" text="📜  Saved Conversion History"
                                    textFill="WHITE">
                                    <font>
                                        <Font name="System Bold" size="22.0" />
                                    </font>
                                </Label>
                                <Region prefHeight="20.0" prefWidth="20.0" HBox.hgrow="ALWAYS" />
                                <Button mnemonicParsing="false" onAction="#handleClearHistory"
                                    fx:id="clearHistoryButton"
                                    prefHeight="34.0" prefWidth="150.0"
                                    style="-fx-font-size: 12; -fx-background-color: #e67e22; -fx-text-fill: white; -fx-background-radius: 6; -fx-cursor: hand;"
                                    text="🗑 Clear History" />
                            </children>
                        </HBox>
                    </children>
                </VBox>
            </top>

            <center>
                <VBox spacing="16.0"
                    style="-fx-padding: 30;"
                    BorderPane.alignment="CENTER">
                    <children>
                        <VBox spacing="12.0"
                            style="-fx-background-color: rgba(255,255,255,0.92); -fx-padding: 24; -fx-background-radius: 12; -fx-border-color: rgba(52,152,219,0.3); -fx-border-radius: 12; -fx-border-width: 1;"
                            VBox.vgrow="ALWAYS">
                            <children>
                                <Label text="All your saved conversions appear below:"
                                    textFill="#5d6d7e">
                                    <font>
                                        <Font size="13.0" />
                                    </font>
                                </Label>
                                <TextArea fx:id="historyTextArea" prefHeight="580.0"
                                    prefWidth="900.0"
                                    wrapText="true" editable="false"
                                    style="-fx-font-size: 14; -fx-background-color: rgba(248,249,250,0.98); -fx-border-color: #dfe6e9; -fx-border-radius: 8; -fx-padding: 10;" />
                            </children>
                        </VBox>
                    </children>
                </VBox>
            </center>
        </BorderPane>
    </children>
</StackPane>